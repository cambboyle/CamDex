# PostgreSQL connection string (from Supabase dashboard → Settings → Database)
DATABASE_URL=postgresql://postgres:[password]@db.[project-id].supabase.co:5432/postgres

# Supabase JWT secret (from Supabase dashboard → Settings → API → JWT Secret)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# URL of the frontend (for CORS)
FRONTEND_URL=http://localhost:5173

# Node environment
NODE_ENV=development

# Server port
PORT=3000

# Set to "true" to enable TypeORM SQL query logging (off by default to keep log stream clean)
DB_LOGGING=false
